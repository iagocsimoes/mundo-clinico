# Credenciais do dashboard /admin (validadas só no servidor)
ADMIN_USER=admin
ADMIN_PASS=troque-esta-senha

# Segredo do cookie de sessão (string aleatória longa; obrigatório em produção
# para as sessões sobreviverem a restarts com credenciais trocadas)
ADMIN_SECRET=

# Caminho do arquivo de leads (opcional; padrão: ./data/leads.json)
# LEADS_FILE=/caminho/para/leads.json
